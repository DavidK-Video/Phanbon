  if(!name || !phone) {
    alert(isVi ? "Vui lòng hoàn thành Họ tên và Số điện thoại liên lạc!" : "Please fill in your Name and Contact Phone Number!");
    return;
  }
  
  // Giả lập xử lý truyền nhận dữ liệu chuyên nghiệp
  alert(isVi ? `Cảm ơn ${name}! Yêu cầu tư vấn quy trình dinh dưỡng cây ${crop} đã được gửi đến ban kỹ sư GoldTech thành công. Hotline 024.8589.8982 sẽ liên lạc với bạn trong vài phút.` 
             : `Thank you ${name}! Your professional crop inquiry for ${crop} culture has been successfully routed to GoldTech Agronomists. Our hotline 024.8589.8982 will establish contact shortly.`);
             
  // Reset form
  document.getElementById('formName').value = "";
  document.getElementById('formPhone').value = "";
  document.getElementById('formEmail').value = "";
  document.getElementById('formCrop').value = "";
  document.getElementById('formMessage').value = "";
}
