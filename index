<script>
// ── SYSTEM ARCHITECTURE: LANGUAGE SWITCHER ──
function setLang(lang) {
  document.body.className = lang;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  if(lang === 'vi') {
    document.getElementById('btnVi').classList.add('active');
  } else {
    document.getElementById('btnEn').classList.add('active');
  }
  document.documentElement.lang = lang;
}

// ── UX INTERACTIVE: MOBILE NAVIGATION MENU ──
function toggleMenu() {
  const navLinks = document.getElementById('navLinks');
  const menuToggle = document.getElementById('menuToggle');
  if (window.innerWidth <= 768) {
    navLinks.classList.toggle('open');
    menuToggle.classList.toggle('open');
  }
}

// ── DATA INTERACTION: TAB SWITCHER MECHANICS ──
function showTab(event, id) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  
  const targetContent = document.getElementById('tab-' + id);
  if (targetContent) {
    targetContent.classList.add('active');
  }
  event.currentTarget.classList.add('active');
}

// ── ANIMATION COMPONENT: NUMERICAL COUNT-UP SYSTEM ──
function animateCounters() {
  const counters = document.querySelectorAll('.stat-num[data-target], .intro-strip-inner .intro-item-num[data-target]');
  counters.forEach(counter => {
    const target = parseFloat(counter.getAttribute('data-target'));
    const isFloat = counter.getAttribute('data-target').includes('.');
    let start = 0;
    const duration = 1500; // milliseconds
    const increment = target / (duration / 16);
    
    const updateCount = () => {
      start += increment;
      if (start < target) {
        counter.innerText = isFloat ? start.toFixed(1) + "M" : Math.floor(start).toLocaleString();
        requestAnimationFrame(updateCount);
      } else {
        counter.innerText = isFloat ? target.toFixed(1) + "M" : target.toLocaleString();
      }
    };
    updateCount();
  });
}

// ── SCROLL DETECTOR: INTERSECTION OBSERVER FOR REVEAL & COUNT-UP ──
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      revealObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

const statsObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      animateCounters();
      statsObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
const triggerElement = document.querySelector('.hero-stats');
if(triggerElement) statsObserver.observe(triggerElement);

// ── DYNAMIC TRACKING: ACTIVE NAVIGATION INDICATOR ──
const navSections = document.querySelectorAll('section[id]');
window.addEventListener('scroll', () => {
  const currentScrollY = window.scrollY + 120;
  navSections.forEach(sec => {
    const link = document.querySelector(`.nav-links a[href="#${sec.id}"]`);
    if (!link) return;
    if (sec.offsetTop <= currentScrollY && sec.offsetTop + sec.offsetHeight > currentScrollY) {
      document.querySelectorAll('.nav-links a').forEach(a => a.style.color = '');
      link.style.color = 'var(--gold-light)';
    }
  });
});

// ── ACTION HANDLER: FORM VALIDATION TRANSMISSION ──
function submitInquiry() {
  const name = document.getElementById('formName').value.trim();
  const phone = document.getElementById('formPhone').value.trim();
