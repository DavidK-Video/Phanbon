<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GoldTech – Phân Bón Hữu Cơ Sinh Học | High-Tech Organic Bio-Fertilizer</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
<style>
:root {
  --green-deep: #0b331a;
  --green-mid: #165231;
  --green-light: #2e8b57;
  --gold: #c9a227;
  --gold-light: #f3df7a;
  --cream: #f7f5ef;
  --white: #ffffff;
  --gray-100: #f4f5f7;
  --gray-300: #d1d5db;
  --gray-600: #4b5563;
  --gray-900: #111827;
  --shadow-sm: 0 4px 12px rgba(0,0,0,.04);
  --shadow-md: 0 10px 30px rgba(0,0,0,.08);
  --shadow-lg: 0 20px 50px rgba(11,51,26,.15);
  --radius: 12px;
  --radius-lg: 24px;
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; color: var(--gray-900); background: var(--white); overflow-x: hidden; -webkit-font-smoothing: antialiased; }

/* ── MULTI-LANGUAGE DECORATOR ── */
[lang-vi], [lang-en] { display: none; }
body.vi [lang-vi] { display: block; }
body.vi [lang-vi-inline] { display: inline; }
body.en [lang-en] { display: block; }
body.en [lang-en-inline] { display: inline; }
body.vi [lang-en-inline], body.en [lang-vi-inline] { display: none; }
span[lang-vi], span[lang-en] { display: inline; }

/* ── NAVIGATION FIXED BAR ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(11, 51, 26, 0.95); backdrop-filter: blur(12px);
  padding: 0 5%; height: 76px; display: flex; align-items: center; justify-content: space-between;
  box-shadow: 0 4px 30px rgba(0,0,0,.15); border-bottom: 1px solid rgba(255,255,255,0.08);
}
.nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
.nav-logo img { height: 46px; width: auto; object-fit: contain; }
.nav-logo-text { font-size: 1.6rem; font-weight: 800; letter-spacing: -0.5px; font-family: 'Inter', sans-serif; }
.nav-logo-text span:first-child { color: var(--gold); }
.nav-logo-text span:last-child { color: var(--white); }

.nav-links { display: flex; gap: 24px; list-style: none; align-items: center; }
.nav-links a { color: rgba(255,255,255,.8); text-decoration: none; font-size: .9rem; font-weight: 500; transition: var(--transition); padding: 6px 0; position: relative; }
.nav-links a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 2px; background: var(--gold); transition: var(--transition); }
.nav-links a:hover { color: var(--gold-light); }
.nav-links a:hover::after { width: 100%; }

.nav-right { display: flex; align-items: center; gap: 16px; }
.lang-toggle { display: flex; border: 1.5px solid rgba(255,255,255,.25); border-radius: 30px; overflow: hidden; padding: 2px; background: rgba(0,0,0,0.2); }
.lang-btn { padding: 6px 14px; font-size: .75rem; font-weight: 700; cursor: pointer; border: none; background: transparent; color: rgba(255,255,255,.5); border-radius: 20px; transition: var(--transition); }
.lang-btn.active { background: var(--gold); color: var(--green-deep); box-shadow: var(--shadow-sm); }
.nav-cta { background: var(--gold); color: var(--green-deep); padding: 10px 22px; border-radius: 8px; font-weight: 700; font-size: .85rem; text-decoration: none; transition: var(--transition); }
.nav-cta:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,162,39,.4); }

/* MOBILE HAMBURGER */
.menu-toggle { display: none; flex-direction: column; gap: 6px; cursor: pointer; background: transparent; border: none; z-index: 1001; }
.menu-toggle span { display: block; width: 28px; height: 3px; background: var(--white); border-radius: 2px; transition: var(--transition); }
.menu-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(6px, 6px); }
.menu-toggle.open span:nth-child(2) { opacity: 0; }
.menu-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(6px, -7px); }

/* ── HERO BANNER SECTION ── */
.hero {
  min-height: 100vh; padding-top: 76px; display: flex; align-items: center; position: relative; overflow: hidden;
  background: linear-gradient(145deg, #072211 0%, #0f3d22 50%, #1a5633 100%);
}
.hero-bg-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.15; pointer-events: none; }
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M40 40v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-40V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 40v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.hero-inner { max-width: 1200px; margin: 0 auto; padding: 60px 5%; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px; align-items: center; width: 100%; position: relative; z-index: 2; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(201,162,39,.12); border: 1px solid rgba(201,162,39,.35); color: var(--gold-light); padding: 8px 18px; border-radius: 30px; font-size: .8rem; font-weight: 600; margin-bottom: 24px; }
.hero h1 { font-family: 'Playfair Display', serif; font-size: 3.8rem; line-height: 1.15; color: var(--white); margin-bottom: 18px; font-weight: 800; }
.hero h1 .gold { color: var(--gold-light); background: linear-gradient(125deg, var(--gold-light), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.hero-sub { font-size: 1.1rem; color: rgba(255,255,255,.75); line-height: 1.75; margin-bottom: 36px; max-width: 580px; font-weight: 300; }
.hero-stats { display: flex; gap: 32px; margin-bottom: 40px; flex-wrap: wrap; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; }
.stat-item { text-align: left; }
.stat-num { font-size: 2.2rem; font-weight: 800; color: var(--gold-light); line-height: 1; letter-spacing: -1px; }
.stat-label { font-size: .78rem; color: rgba(255,255,255,.5); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.hero-btns { display: flex; gap: 16px; flex-wrap: wrap; }
.btn-primary { background: var(--gold); color: var(--green-deep); padding: 16px 32px; border-radius: 10px; font-weight: 700; font-size: .95rem; text-decoration: none; transition: var(--transition); display: inline-flex; align-items: center; gap: 10px; box-shadow: 0 4px 15px rgba(201,162,39,0.2); }
.btn-primary:hover { background: var(--gold-light); transform: translateY(-3px); box-shadow: 0 10px 25px rgba(201,162,39,.4); }
.btn-outline { border: 2px solid rgba(255,255,255,.3); color: var(--white); padding: 16px 32px; border-radius: 10px; font-weight: 600; font-size: .95rem; text-decoration: none; transition: var(--transition); display: inline-flex; align-items: center; gap: 10px; }
.btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,.08); transform: translateY(-2px); }

.hero-product { position: relative; display: flex; justify-content: center; align-items: center; }
.product-glow { width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(46,139,87,.25) 0%, transparent 70%); position: absolute; filter: blur(20px); }
.product-card { background: rgba(255,255,255,.07); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,.18); border-radius: 32px; padding: 40px 32px; text-align: center; position: relative; z-index: 1; width: 100%; max-width: 360px; box-shadow: var(--shadow-lg); transition: var(--transition); }
.product-card:hover { transform: translateY(-5px); border-color: rgba(201,162,39,0.4); }
.product-image-container { width: 100%; height: 220px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; border-radius: 16px; background: rgba(0,0,0,0.15); overflow: hidden; position: relative; }
.product-image-container img { max-height: 90%; max-width: 90%; object-fit: contain; z-index: 2; }
.product-image-container::before { content: 'GOLDTECH G05'; position: absolute; font-size: 2.5rem; font-weight: 900; color: rgba(255,255,255,0.03); z-index: 1; letter-spacing: 2px; }
.product-name { font-size: 2.2rem; font-weight: 900; color: var(--gold-light); line-height: 1.2; margin-bottom: 4px; }
.product-subtitle { color: rgba(255,255,255,.7); font-size:.9rem; margin-bottom: 18px; font-weight: 400; }
.product-tags { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 22px; }
.product-tags .tag { background: rgba(46,139,87,.25); border: 1px solid rgba(46,139,87,.4); color: #8eeebb; padding: 4px 10px; border-radius: 8px; font-size: .7rem; font-weight: 600; text-transform: uppercase; }
.product-price { font-size: 1.8rem; font-weight: 800; color: var(--gold-light); letter-spacing: -0.5px; }
.product-price-label { font-size: .8rem; color: rgba(255,255,255,.45); margin-top: 2px; }

/* ── VALUE STRIP BAR ── */
.intro-strip { background: var(--green-deep); padding: 44px 5%; border-bottom: 1px solid rgba(255,255,255,0.05); }
.intro-strip-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; text-align: center; }
.intro-item { color: var(--white); display: flex; flex-direction: column; align-items: center; position: relative; }
.intro-item:not(:last-child)::after { content: ''; position: absolute; right: -12px; top: 15%; height: 70%; width: 1px; background: rgba(255,255,255,0.1); }
.intro-item-icon { width: 44px; height: 44px; fill: var(--gold); margin-bottom: 12px; background: rgba(255,255,255,0.04); padding: 10px; border-radius: 50%; }
.intro-item-num { font-size: 2rem; font-weight: 800; color: var(--gold-light); line-height: 1.2; }
.intro-item-text { font-size: .82rem; color: rgba(255,255,255,.6); margin-top: 6px; font-weight: 400; line-height: 1.4; }

/* ── GLOBAL SECTIONS LAYOUT ── */
section { padding: 100px 5%; position: relative; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: .75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--green-light); margin-bottom: 16px; }
.section-eyebrow::before { content: ''; width: 32px; height: 2px; background: var(--green-light); display: inline-block; }
h2.section-title { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 800; color: var(--green-deep); line-height: 1.2; margin-bottom: 20px; letter-spacing: -0.5px; }
.section-desc { font-size: 1.1rem; color: var(--gray-600); line-height: 1.8; max-width: 720px; font-weight: 400; margin-bottom: 40px; }

/* ── ABOUT & VISION SECTION ── */
.about { background: var(--cream); }
.about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: start; }
.about-text p { font-size: 1.05rem; color: var(--gray-600); line-height: 1.85; margin-bottom: 20px; text-align: justify; }
.about-text strong { color: var(--green-deep); font-weight: 700; }
.mission-boxes { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 36px; }
.mission-box { padding: 32px; border-radius: var(--radius); box-shadow: var(--shadow-md); transition: var(--transition); }
.mission-box:hover { transform: translateY(-4px); }
.mission-box.green { background: var(--green-deep); color: var(--white); }
.mission-box.gold { background: var(--gold); color: var(--green-deep); }
.mission-box h3 { font-size: 1.2rem; font-weight: 800; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 10px; }
.mission-box h3 svg { width: 24px; height: 24px; fill: currentColor; }
.mission-box p { font-size: .92rem; line-height: 1.7; opacity: .9; font-weight: 400; }

.values-grid { display: flex; flex-direction: column; gap: 20px; }
.value-card { background: var(--white); border-radius: var(--radius); padding: 28px; border-left: 5px solid var(--green-light); box-shadow: var(--shadow-sm); transition: var(--transition); }
.value-card:hover { transform: translateX(6px); box-shadow: var(--shadow-md); border-left-color: var(--gold); }
.value-card h4 { font-size: 1.1rem; font-weight: 700; color: var(--green-deep); margin-bottom: 10px; display: flex; align-items: center; gap: 12px; }
.value-card h4 svg { width: 24px; height: 24px; fill: var(--green-mid); }
.value-card p { font-size: .92rem; color: var(--gray-600); line-height: 1.65; }

/* ── MANUFACTURING TECHNOLOGY ── */
.tech { background: var(--white); }
.tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 20px; }
.tech-card { background: var(--cream); border-radius: var(--radius-lg); padding: 40px 32px; position: relative; overflow: hidden; transition: var(--transition); box-shadow: var(--shadow-sm); border: 1px solid rgba(0,0,0,0.02); }
.tech-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-md); }
.tech-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 5px; }
.tech-card.nano::before { background: linear-gradient(90deg, #2d7a4f, #4caf74); }
.tech-card.bio::before { background: linear-gradient(90deg, #c9a227, #f0c040); }
.tech-card.eco::before { background: linear-gradient(90deg, #1e40af, #3b82f6); }
.tech-icon-wrap { width: 60px; height: 60px; border-radius: 16px; background: var(--white); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; box-shadow: var(--shadow-sm); }
.tech-icon-wrap svg { width: 32px; height: 32px; }
.tech-card.nano svg { fill: var(--green-mid); }
.tech-card.bio svg { fill: var(--gold); }
.tech-card.eco svg { fill: #1e40af; }
.tech-card h3 { font-size: 1.3rem; font-weight: 700; color: var(--green-deep); margin-bottom: 16px; }
.tech-card ul { list-style: none; padding: 0; }
.tech-card ul li { font-size: .9rem; color: var(--gray-600); line-height: 1.7; margin-bottom: 12px; padding-left: 22px; position: relative; text-align: justify; }
.tech-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--green-light); font-weight: 700; }

/* ── CORE ADVANTAGES ── */
.advantages { background: linear-gradient(145deg, #072211, #0f361d); color: var(--white); }
.advantages h2.section-title { color: var(--white); }
.advantages .section-eyebrow { color: var(--gold-light); }
.advantages .section-eyebrow::before { background: var(--gold-light); }
.advantages .section-desc { color: rgba(255,255,255,0.7); }
.adv-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; }
.adv-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); border-radius: var(--radius); padding: 32px; transition: var(--transition); }
.adv-card:hover { background: rgba(255,255,255,.08); border-color: rgba(201,162,39,0.3); transform: translateY(-4px); }
.adv-card h4 { font-size: 1.15rem; font-weight: 700; color: var(--gold-light); margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
.adv-card h4 svg { width: 24px; height: 24px; fill: var(--gold-light); }
.adv-card ul { list-style: none; }
.adv-card ul li { font-size: .92rem; color: rgba(255,255,255,.8); line-height: 1.7; margin-bottom: 10px; padding-left: 24px; position: relative; }
.adv-card ul li::before { content: '✓'; position: absolute; left: 0; color: #5cdb95; font-weight: 700; }

/* ── PRODUCTS GRID SECTION ── */
.products-section { background: var(--white); }
.products-showcase { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 40px; }
.prod-item-card { background: var(--cream); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgba(0,0,0,0.03); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; transition: var(--transition); }
.prod-item-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: rgba(46,139,87,0.2); }
.prod-img-box { width: 100%; height: 240px; background: rgba(0,0,0,0.03); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.prod-img-box img { max-height: 85%; max-width: 85%; object-fit: contain; }
.prod-img-placeholder { position: absolute; font-size: 0.8rem; font-weight: 600; color: var(--gray-600); background: rgba(255,255,255,0.8); padding: 4px 10px; border-radius: 4px; bottom: 10px; border: 1px dashed var(--gray-300); }
.prod-details { padding: 28px; flex-grow: 1; display: flex; flex-direction: column; }
.prod-code-tag { font-size: .72rem; font-weight: 700; color: var(--gold); background: rgba(201,162,39,0.1); padding: 4px 10px; border-radius: 6px; align-self: flex-start; margin-bottom: 12px; letter-spacing: 0.5px; }
.prod-details h4 { font-size: 1.25rem; font-weight: 700; color: var(--green-deep); margin-bottom: 10px; }
.prod-comp { font-size: .85rem; color: var(--gray-600); line-height: 1.65; text-align: justify; }

/* ── FACTORY OVERVIEW ── */
.factory { background: var(--cream); }
.factory-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.factory-text p { font-size: 1.05rem; color: var(--gray-600); line-height: 1.85; margin-bottom: 18px; text-align: justify; }
.factory-text strong { color: var(--green-deep); font-weight: 700; }
.factory-img-wrap { position: relative; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg); height: 380px; background: var(--green-deep); display: flex; align-items: center; justify-content: center; }
.factory-img-wrap img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
.factory-img-placeholder { position: absolute; color: var(--white); font-weight: 500; font-size: 0.95rem; border: 1px dashed rgba(255,255,255,0.4); padding: 12px 24px; border-radius: 8px; background: rgba(0,0,0,0.4); backdrop-filter: blur(5px); }
.factory-specs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 36px; }
.spec-box { background: var(--white); border-radius: var(--radius); padding: 24px 16px; text-align: center; box-shadow: var(--shadow-sm); border: 1px solid rgba(0,0,0,0.02); transition: var(--transition); }
.spec-box:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
.spec-box .spec-val { font-size: 1.8rem; font-weight: 800; color: var(--green-deep); letter-spacing: -0.5px; }
.spec-box .spec-key { font-size: .75rem; color: var(--gray-600); margin-top: 6px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }

/* ── LEGAL CERTIFICATIONS ── */
.certs { background: var(--white); }
.certs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.cert-card { background: var(--cream); border: 2px solid var(--gray-300); border-radius: var(--radius); padding: 32px 24px; text-align: center; transition: var(--transition); display: flex; flex-direction: column; align-items: center; }
.cert-card:hover { border-color: var(--green-light); box-shadow: var(--shadow-md); transform: translateY(-4px); background: var(--white); }
.cert-icon-wrap { width: 54px; height: 54px; margin-bottom: 16px; fill: var(--green-mid); display: flex; align-items: center; justify-content: center; }
.cert-card h4 { font-size: 1rem; font-weight: 700; color: var(--green-deep); margin-bottom: 8px; line-height: 1.4; min-height: 44px; display: flex; align-items: center; }
.cert-card p { font-size: .82rem; color: var(--gray-600); line-height: 1.6; flex-grow: 1; text-align: center; }
.cert-badge { display: inline-block; background: var(--green-deep); color: var(--white); font-size: .68rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; margin-top: 14px; letter-spacing: 0.5px; }

/* ── EXPERIMENTAL ECO RESULTS ── */
.results { background: var(--cream); }
.results-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; border-bottom: 2px solid var(--gray-300); padding-bottom: 16px; }
.tab-btn { padding: 10px 20px; border-radius: 8px; font-size: .85rem; font-weight: 600; cursor: pointer; border: 1px solid var(--gray-300); background: var(--white); color: var(--gray-600); transition: var(--transition); }
.tab-btn:hover { border-color: var(--green-mid); color: var(--green-mid); }
.tab-btn.active { background: var(--green-deep); color: var(--white); border-color: var(--green-deep); box-shadow: var(--shadow-sm); }
.tab-content { display: none; }
.tab-content.active { display: block; animation: fadeIn 0.4s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

.result-table-wrap { overflow-x: auto; border-radius: var(--radius); box-shadow: var(--shadow-md); border: 1px solid var(--gray-300); }
table { width: 100%; border-collapse: collapse; background: var(--white); font-size: .88rem; min-width: 600px; }
thead { background: var(--green-deep); color: var(--white); }
thead th { padding: 16px; text-align: left; font-weight: 600; font-size: .9rem; border-bottom: 2px solid rgba(0,0,0,0.1); }
tbody tr { border-bottom: 1px solid var(--gray-300); transition: var(--transition); }
tbody tr:nth-child(even) { background: var(--gray-100); }
tbody tr:hover { background: rgba(46,139,87,.08); }
tbody td { padding: 14px 16px; color: var(--gray-900); font-weight: 400; }
tbody td.highlight { font-weight: 700; color: var(--green-mid); font-size: 0.95rem; }
tbody td.gold-text { font-weight: 700; color: #b58d15; }
.result-note { margin-top: 24px; background: var(--green-deep); border-radius: var(--radius); padding: 24px 32px; color: var(--white); border-left: 6px solid var(--gold); box-shadow: var(--shadow-sm); }
